{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xelians.fr/sipg/seda-json/1.0/seda-json-schema.json",
  "title": "SEDA JSON 1.0 manifest",
  "description": "JSON transposition of the SEDA v2 archive transfer covering the complete sipg ontology. Data objects are declared inline in their archive unit and the unit hierarchy is expressed by nesting only. The key order is normative (mirroring the SEDA XSD sequence) but is enforced by the streaming parser, not by this schema. Extended elements are allowed in Content only.",
  "type": "object",
  "properties": {
    "SedaJsonVersion": {
      "const": "1.0"
    },
    "MessageIdentifier": {
      "type": "string",
      "maxLength": 1024
    },
    "Comment": {
      "type": "string",
      "maxLength": 5000
    },
    "ArchivalAgreement": {
      "$ref": "#/$defs/text512"
    },
    "ArchiveUnits": {
      "$ref": "#/$defs/archiveUnits"
    },
    "ManagementMetadata": {
      "$ref": "#/$defs/managementMetadata"
    },
    "ArchivalAgency": {
      "$ref": "#/$defs/agency"
    },
    "TransferringAgency": {
      "$ref": "#/$defs/agency"
    }
  },
  "required": [
    "SedaJsonVersion",
    "ArchivalAgreement",
    "ArchivalAgency"
  ],
  "additionalProperties": false,
  "$defs": {
    "text512": {
      "type": "string",
      "maxLength": 512
    },
    "textArray512": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "$ref": "#/$defs/text512"
      }
    },
    "langText1024": {
      "oneOf": [
        {
          "type": "string",
          "maxLength": 1024
        },
        {
          "type": "object",
          "properties": {
            "Lang": {
              "type": "string",
              "maxLength": 64
            },
            "Value": {
              "type": "string",
              "maxLength": 1024
            }
          },
          "required": [
            "Lang",
            "Value"
          ],
          "additionalProperties": false
        }
      ]
    },
    "langText131072": {
      "oneOf": [
        {
          "type": "string",
          "maxLength": 131072
        },
        {
          "type": "object",
          "properties": {
            "Lang": {
              "type": "string",
              "maxLength": 64
            },
            "Value": {
              "type": "string",
              "maxLength": 131072
            }
          },
          "required": [
            "Lang",
            "Value"
          ],
          "additionalProperties": false
        }
      ]
    },
    "date": {
      "type": "string",
      "format": "date",
      "maxLength": 64
    },
    "dateTime": {
      "type": "string",
      "maxLength": 64
    },
    "agency": {
      "type": "object",
      "properties": {
        "Identifier": {
          "$ref": "#/$defs/text512"
        },
        "OrganizationDescriptiveMetadata": {
          "type": "object",
          "properties": {
            "Name": {
              "$ref": "#/$defs/text512"
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "Identifier"
      ],
      "additionalProperties": false
    },
    "managementMetadata": {
      "type": "object",
      "properties": {
        "ArchivalProfile": {
          "$ref": "#/$defs/text512"
        },
        "ServiceLevel": {
          "$ref": "#/$defs/text512"
        },
        "AcquisitionInformation": {
          "$ref": "#/$defs/text512"
        },
        "LegalStatus": {
          "$ref": "#/$defs/text512"
        },
        "OriginatingAgencyIdentifier": {
          "$ref": "#/$defs/text512"
        },
        "SubmissionAgencyIdentifier": {
          "$ref": "#/$defs/text512"
        }
      },
      "additionalProperties": false
    },
    "archiveUnits": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/archiveUnit"
      }
    },
    "archiveUnit": {
      "type": "object",
      "properties": {
        "Management": {
          "$ref": "#/$defs/management"
        },
        "Content": {
          "$ref": "#/$defs/content"
        },
        "BinaryDataObjects": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/binaryDataObject"
          }
        },
        "PhysicalDataObjects": {
          "type": "array",
          "maxItems": 1,
          "items": {
            "$ref": "#/$defs/physicalDataObject"
          }
        },
        "ArchiveUnits": {
          "$ref": "#/$defs/archiveUnits"
        }
      },
      "required": [
        "Content"
      ],
      "additionalProperties": false
    },
    "content": {
      "type": "object",
      "properties": {
        "DescriptionLevel": {
          "$ref": "#/$defs/text512"
        },
        "Title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024
        },
        "Titles": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/langText1024"
          }
        },
        "FilePlanPositions": {
          "$ref": "#/$defs/textArray512"
        },
        "SystemIds": {
          "$ref": "#/$defs/textArray512"
        },
        "OriginatingSystemIds": {
          "$ref": "#/$defs/textArray512"
        },
        "ArchivalAgencyArchiveUnitIdentifiers": {
          "$ref": "#/$defs/textArray512"
        },
        "OriginatingAgencyArchiveUnitIdentifiers": {
          "$ref": "#/$defs/textArray512"
        },
        "TransferringAgencyArchiveUnitIdentifiers": {
          "$ref": "#/$defs/textArray512"
        },
        "Description": {
          "type": "string",
          "maxLength": 131072
        },
        "Descriptions": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/langText131072"
          }
        },
        "CustodialHistoryItems": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/custodialItem"
          }
        },
        "ArchiveUnitProfile": {
          "$ref": "#/$defs/text512"
        },
        "Type": {
          "$ref": "#/$defs/text512"
        },
        "DocumentType": {
          "$ref": "#/$defs/text512"
        },
        "Languages": {
          "$ref": "#/$defs/textArray512"
        },
        "DescriptionLanguage": {
          "$ref": "#/$defs/text512"
        },
        "Status": {
          "$ref": "#/$defs/text512"
        },
        "Version": {
          "$ref": "#/$defs/text512"
        },
        "Tags": {
          "$ref": "#/$defs/textArray512"
        },
        "Keywords": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "$ref": "#/$defs/keyword"
          }
        },
        "OriginatingAgency": {
          "$ref": "#/$defs/agency"
        },
        "SubmissionAgency": {
          "$ref": "#/$defs/agency"
        },
        "Agents": {
          "$ref": "#/$defs/agentArray"
        },
        "AuthorizedAgents": {
          "$ref": "#/$defs/agentArray"
        },
        "Writers": {
          "$ref": "#/$defs/agentArray"
        },
        "Addressees": {
          "$ref": "#/$defs/agentArray"
        },
        "Recipients": {
          "$ref": "#/$defs/agentArray"
        },
        "Transmitters": {
          "$ref": "#/$defs/agentArray"
        },
        "Senders": {
          "$ref": "#/$defs/agentArray"
        },
        "Source": {
          "$ref": "#/$defs/text512"
        },
        "RelatedObjectReference": {
          "$ref": "#/$defs/relatedObjectReference"
        },
        "CreatedDate": {
          "$ref": "#/$defs/date"
        },
        "TransactedDate": {
          "$ref": "#/$defs/date"
        },
        "AcquiredDate": {
          "$ref": "#/$defs/date"
        },
        "SentDate": {
          "$ref": "#/$defs/date"
        },
        "ReceivedDate": {
          "$ref": "#/$defs/date"
        },
        "RegisteredDate": {
          "$ref": "#/$defs/date"
        },
        "StartDate": {
          "$ref": "#/$defs/date"
        },
        "EndDate": {
          "$ref": "#/$defs/date"
        },
        "Events": {
          "type": "array",
          "maxItems": 10000,
          "items": {
            "$ref": "#/$defs/event"
          }
        },
        "Signatures": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "$ref": "#/$defs/signature"
          }
        },
        "SigningInformation": {
          "$ref": "#/$defs/signingInformation"
        },
        "Gps": {
          "$ref": "#/$defs/gps"
        },
        "FullText": {
          "type": "string",
          "maxLength": 131072
        }
      },
      "required": [
        "Title"
      ],
      "additionalProperties": true
    },
    "custodialItem": {
      "oneOf": [
        {
          "$ref": "#/$defs/text512"
        },
        {
          "type": "object",
          "properties": {
            "Value": {
              "$ref": "#/$defs/text512"
            },
            "When": {
              "$ref": "#/$defs/dateTime"
            }
          },
          "required": [
            "Value"
          ],
          "additionalProperties": false
        }
      ]
    },
    "keyword": {
