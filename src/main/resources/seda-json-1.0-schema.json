    "rule": {
      "type": "object",
      "properties": {
        "Rule": {
          "$ref": "#/$defs/text512"
        },
        "StartDate": {
          "$ref": "#/$defs/date"
        }
      },
      "required": [
        "Rule"
      ],
      "additionalProperties": false
    },
    "rules": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "commonRule": {
      "type": "object",
      "properties": {
        "Rules": {
          "$ref": "#/$defs/rules"
        },
        "PreventInheritance": {
          "type": "boolean"
        },
        "PreventRuleNames": {
          "$ref": "#/$defs/textArray512"
        }
      },
      "not": {
        "required": [
          "PreventInheritance",
          "PreventRuleNames"
        ]
      },
      "additionalProperties": false
    },
    "appraisalRule": {
      "type": "object",
      "properties": {
        "Rules": {
          "$ref": "#/$defs/rules"
        },
        "PreventInheritance": {
          "type": "boolean"
        },
        "PreventRuleNames": {
          "$ref": "#/$defs/textArray512"
        },
        "Duration": {
          "$ref": "#/$defs/text512"
        },
        "FinalAction": {
          "enum": [
            "Keep",
            "Destroy"
          ]
        }
      },
      "not": {
        "required": [
          "PreventInheritance",
          "PreventRuleNames"
        ]
      },
      "additionalProperties": false
    },
    "storageRule": {
      "type": "object",
      "properties": {
        "Rules": {
          "$ref": "#/$defs/rules"
        },
        "PreventInheritance": {
          "type": "boolean"
        },
        "PreventRuleNames": {
          "$ref": "#/$defs/textArray512"
        },
        "FinalAction": {
          "enum": [
            "Copy",
            "RestrictAccess",
            "Transfer"
          ]
        }
      },
      "not": {
        "required": [
          "PreventInheritance",
          "PreventRuleNames"
        ]
      },
