        "NeedAuthorization": {
          "type": "boolean"
        },
        "HoldRule": {
          "$ref": "#/$defs/holdRule"
        },
        "UpdateOperation": {
          "$ref": "#/$defs/updateOperation"
        }
      },
      "additionalProperties": false
